test_fuzz_settlement_block_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_settlement_block_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_settlement_block_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
# settlement_block is the first fuzz target to pull the full server+wallet+sapling
# closure (ProcessSpecialTxsInBlock -> settlementdb -> ... -> node/init, wallet,
# sapling), which has circular inter-archive refs. The unit-test binary resolves
# them because its own test objects reference wallet symbols before the wallet
# archive is scanned; the fuzz binary's objects reference only settlement, so the
# server archive pulls its full closure and back-references the (already-scanned)
# wallet/sapling archives. automake forbids -Wl,--start-group in _LDADD, so instead
# repeat the internal archives a second time: single-pass ld re-scans the trailing
# copies and resolves the forward references (equivalent to a 2-pass group).
if ENABLE_WALLET
SETTLEMENT_FUZZ_WALLET_REPEAT = $(LIBBITCOIN_WALLET)
endif
if ENABLE_ZMQ
SETTLEMENT_FUZZ_ZMQ_REPEAT = $(LIBBITCOIN_ZMQ) $(ZMQ_LIBS)
endif
test_fuzz_settlement_block_LDADD = $(test_test_bathron_fuzzy_LDADD) \
  $(LIBBITCOIN_SERVER) $(SETTLEMENT_FUZZ_WALLET_REPEAT) $(LIBSAPLING) $(LIBBITCOIN_CONSENSUS) \
  $(LIBBITCOIN_COMMON) $(LIBBITCOIN_UTIL) $(LIBBITCOIN_CRYPTO) $(LIBRUSTZCASH) $(LIBZCASH_LIBS) \
  $(SETTLEMENT_FUZZ_ZMQ_REPEAT)

# husig_wire (hard-test #7): the HUSIG finality-signature wire chokepoint —
# CHuSignature deserialize + ECDSA RecoverCompact + ECVRF Verify on hostile bytes.
# Same full server+wallet+sapling+VRF closure as settlement_block (state/signaling,
# state/finality, vrf pull node/init, wallet, sapling), so mirror its LDADD (incl.
# the trailing archive repeat that resolves the circular inter-archive refs).
test_fuzz_husig_wire_SOURCES = $(FUZZ_SUITE) test/fuzz/husig_wire.cpp
test_fuzz_husig_wire_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_husig_wire_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_husig_wire_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
test_fuzz_husig_wire_LDADD = $(test_test_bathron_fuzzy_LDADD) \
  $(LIBBITCOIN_SERVER) $(SETTLEMENT_FUZZ_WALLET_REPEAT) $(LIBSAPLING) $(LIBBITCOIN_CONSENSUS) \
  $(LIBBITCOIN_COMMON) $(LIBBITCOIN_UTIL) $(LIBBITCOIN_CRYPTO) $(LIBRUSTZCASH) $(LIBZCASH_LIBS) \
  $(SETTLEMENT_FUZZ_ZMQ_REPEAT)

