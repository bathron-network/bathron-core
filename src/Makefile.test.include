# mint_m0btc + htlc: pure WIRE-payload fuzzers. mint fuzzes the MintPayload
# deserialize/round-trip only (semantic IsTriviallyValid lives in burnclaim.cpp,
# which would drag the whole server closure — that path is covered by unit tests +
# the settlement_block fuzzer). htlc uses the inline IsTriviallyValid in htlc.h.
# Both build against the minimal fuzzy LDADD (proven links, 0 crash).
test_fuzz_mint_m0btc_SOURCES = $(FUZZ_SUITE) test/fuzz/mint_m0btc.cpp
test_fuzz_mint_m0btc_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_mint_m0btc_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_mint_m0btc_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
test_fuzz_mint_m0btc_LDADD = $(test_test_bathron_fuzzy_LDADD)

test_fuzz_htlc_SOURCES = $(FUZZ_SUITE) test/fuzz/htlc.cpp
test_fuzz_htlc_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_htlc_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_htlc_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
test_fuzz_htlc_LDADD = $(test_test_bathron_fuzzy_LDADD)

# sapling_tx: SaplingValidation::CheckTransaction pulls libsapling + librustzcash
# (Params()/consensus + the Rust shielded verifier archive), so it needs the full
# server+wallet+sapling closure like settlement_block/husig_wire.
test_fuzz_sapling_tx_SOURCES = $(FUZZ_SUITE) test/fuzz/sapling_tx.cpp
test_fuzz_sapling_tx_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_sapling_tx_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_sapling_tx_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
test_fuzz_sapling_tx_LDADD = $(test_test_bathron_fuzzy_LDADD) \
  $(LIBBITCOIN_SERVER) $(SETTLEMENT_FUZZ_WALLET_REPEAT) $(LIBSAPLING) $(LIBBITCOIN_CONSENSUS) \
  $(LIBBITCOIN_COMMON) $(LIBBITCOIN_UTIL) $(LIBBITCOIN_CRYPTO) $(LIBRUSTZCASH) $(LIBZCASH_LIBS) \
  $(SETTLEMENT_FUZZ_ZMQ_REPEAT)

# merkle_proof: CBtcSPV::VerifyMerkleProof lives in the btcspv module (server closure);
# same full LDADD as settlement_block/husig_wire.
test_fuzz_merkle_proof_SOURCES = $(FUZZ_SUITE) test/fuzz/merkle_proof.cpp
test_fuzz_merkle_proof_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES)
test_fuzz_merkle_proof_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_fuzz_merkle_proof_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS)
test_fuzz_merkle_proof_LDADD = $(test_test_bathron_fuzzy_LDADD) \
  $(LIBBITCOIN_SERVER) $(SETTLEMENT_FUZZ_WALLET_REPEAT) $(LIBSAPLING) $(LIBBITCOIN_CONSENSUS) \
  $(LIBBITCOIN_COMMON) $(LIBBITCOIN_UTIL) $(LIBBITCOIN_CRYPTO) $(LIBRUSTZCASH) $(LIBZCASH_LIBS) \
  $(SETTLEMENT_FUZZ_ZMQ_REPEAT)

